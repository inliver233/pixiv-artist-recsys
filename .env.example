# Local runtime paths (optional; defaults live under ./data)
# PIXIV_ARTIST_RECSYS_DATA_DIR=./data
# PIXIV_ARTIST_RECSYS_RUNTIME_DIR=./data/runtime
# PIXIV_ARTIST_RECSYS_DB_PATH=./data/runtime/pixiv_artist_recsys.sqlite3
# PIXIV_ARTIST_RECSYS_MODE=development

# Local API
# PIXIV_ARTIST_RECSYS_API_HOST=127.0.0.1
# PIXIV_ARTIST_RECSYS_API_PORT=8787

# Recommendation defaults
# PIXIV_ARTIST_RECSYS_MAX_CANDIDATES=300
# PIXIV_ARTIST_RECSYS_MAX_RESULTS=50
# PIXIV_ARTIST_RECSYS_FRESHNESS_DAYS=180
# PIXIV_ARTIST_RECSYS_ALLOW_AI=false
# PIXIV_ARTIST_RECSYS_ALLOW_R18=false
# PIXIV_ARTIST_RECSYS_MIN_BOOKMARKS=30
# PIXIV_ARTIST_RECSYS_MIN_SCORE=0.5
# PIXIV_ARTIST_RECSYS_DIVERSITY_PER_TAG=2

# Secrets: DO NOT commit real tokens. This file is NOT auto-loaded — export in shell or pass CLI flags.
# Preferred:
#   $env:PIXIV_ARTIST_RECSYS_REFRESH_TOKEN = "your-refresh-token"
# Alias also accepted by runtime:
#   $env:PIXIV_REFRESH_TOKEN = "your-refresh-token"
#   python -m pixiv_artist_recsys full-recommend --seed-user-id 123 --refresh-token $env:PIXIV_ARTIST_RECSYS_REFRESH_TOKEN
# PIXIV_ARTIST_RECSYS_REFRESH_TOKEN=
# PIXIV_ARTIST_RECSYS_ACCESS_TOKEN=
#
# Optional proxy list (comma-separated). Leave empty for direct.
# PIXIV_ARTIST_RECSYS_PROXY_URLS=
# PIXIV_ARTIST_RECSYS_PROXY_MAX_FAILURES=1
# PIXIV_ARTIST_RECSYS_PROXY_COOLDOWN_SECONDS=60
# PIXIV_ARTIST_RECSYS_PROXY_ALLOW_DIRECT=1

# HTTP retry / backoff (429/5xx)
# PIXIV_ARTIST_RECSYS_HTTP_MAX_ATTEMPTS=3
# PIXIV_ARTIST_RECSYS_HTTP_RETRY_BASE_DELAY_S=0.5
